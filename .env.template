# =========================
# App / Backend
# =========================
APP_NAME=project-manager
APP_PORT=8080
JWT_SECRET=change-me-in-production
CORS_ALLOW_ORIGINS=http://localhost:5173,https://localhost:5443
UPLOAD_DIR=../static/uploads
UPLOAD_PUBLIC_BASE=/static/uploads

# =========================
# Database (used by backend)
# =========================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=project_management

# =========================
# Task Notifications (Backend)
# 说明：
# 1) 邮件通知可与其它渠道并存；
# 2) 企业微信 / 钉钉 / 飞书 三选一（仅可配置一种）；
# 3) 任一渠道所需变量为空时，该渠道不会发送通知。
# =========================

# 非邮件渠道选择：留空=自动识别；可选 wecom / dingtalk / feishu / none
TASK_NOTIFY_PROVIDER=

# -- Email (SMTP) --
SMTP_HOST=
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
# 仅用于 scripts/test-task-notify.sh，自检收件人（不影响系统运行）
SMTP_TEST_TO=

# -- WeCom (企业微信应用消息) --
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_AGENT_ID=
WECOM_TO_USER=@all

# -- DingTalk (钉钉机器人 Webhook) --
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# -- Feishu (飞书服务端消息) --
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 默认为 email；可选 open_id/union_id/user_id/email/chat_id
FEISHU_RECEIVE_ID_TYPE=email
# 留空时：若 receive_id_type=email，则按任务执行人邮箱逐个发送
FEISHU_RECEIVE_ID=

# =========================
# AI Assistant (洞察分析 -> AI 助理)
# 说明：
# 1) 走 OpenAI 兼容的 chat/completions 网关（OpenAI / Azure / 自建代理均可）；
# 2) AI_BASE_URL、AI_API_KEY、AI_MODEL 三者需同时配置才会启用；
# 3) 任一为空则 AI 助理自动回退到内置模板，绝不外发项目数据。
# =========================
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_SECONDS=30

# =========================
# Docker Compose runtime
# =========================
MYSQL_IMAGE=registry.cn-guangzhou.aliyuncs.com/joe/mysql:lts
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=project_management
GO_BUILDER_IMAGE=registry.cn-guangzhou.aliyuncs.com/joe/golang:1.25-alpine
APP_RUNTIME_IMAGE=registry.cn-guangzhou.aliyuncs.com/joe/alpine:latest
NODE_BUILDER_IMAGE=registry.cn-guangzhou.aliyuncs.com/joe/node:24-alpine
NGINX_IMAGE=registry.cn-guangzhou.aliyuncs.com/joe/nginx:alpine
# Go 工具链标准变量是 GOPROXY；GO_PROXY 保留给旧脚本兼容。
GOPROXY=https://goproxy.cn,direct
GO_PROXY=https://goproxy.cn,direct
NPM_REGISTRY=https://registry.npmmirror.com

BACKEND_PORT=8080
FRONTEND_PORT=5173
FRONTEND_HTTPS_PORT=5443
FRONTEND_SSL_DIR=./deploy/ssl
FRONTEND_SSL_CERT_FILE=fullchain.pem
FRONTEND_SSL_KEY_FILE=privkey.pem

# =========================
# Frontend runtime (Vite)
# =========================
VITE_API_BASE_URL=/api/v1
