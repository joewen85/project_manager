# =========================
# App / Backend
# =========================
APP_NAME=project-manager
APP_PORT=8080
JWT_SECRET=change-me-in-production
CORS_ALLOW_ORIGINS=http://localhost:5173
UPLOAD_DIR=../static/uploads
UPLOAD_PUBLIC_BASE=/static/uploads

# =========================
# Database (used by backend)
# =========================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=project_management

# =========================
# Docker Compose runtime
# =========================
MYSQL_IMAGE=registry.cn-guangzhou.aliyuncs.com/joe/mysql:lts
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=project_management
GO_BUILDER_IMAGE=golang:1.25-alpine
APP_RUNTIME_IMAGE=alpine:3.20
NODE_BUILDER_IMAGE=node:22-alpine
NGINX_IMAGE=registry.cn-guangzhou.aliyuncs.com/joe/nginx:alpine
GO_PROXY=https://goproxy.cn,direct
NPM_REGISTRY=https://registry.npmmirror.com

BACKEND_PORT=8080
FRONTEND_PORT=5173
FRONTEND_HTTPS_PORT=5443
FRONTEND_SSL_DIR=./deploy/ssl
FRONTEND_SSL_CERT_FILE=fullchain.pem
FRONTEND_SSL_KEY_FILE=privkey.pem

# =========================
# Frontend runtime (Vite)
# =========================
VITE_API_BASE_URL=/api/v1
